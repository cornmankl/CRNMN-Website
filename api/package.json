{
    "name": "cornman-api",
    "version": "1.0.0",
    "description": "CORNMAN Public API - Comprehensive REST and GraphQL API for third-party integrations",
    "main": "src/index.js",
    "type": "module",
    "scripts": {
        "start": "node src/index.js",
        "dev": "nodemon src/index.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "docs:generate": "swagger-jsdoc -d config/swagger.js src/routes/*.js -o docs/swagger.json",
        "docs:serve": "swagger-ui-serve docs/swagger.json",
        "sdk:generate": "node scripts/generate-sdks.js",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix"
    },
    "keywords": [
        "api",
        "rest",
        "graphql",
        "cornman",
        "restaurant",
        "food-delivery",
        "integration"
    ],
    "author": "CORNMAN Team",
    "license": "MIT",
    "dependencies": {
        "express": "^4.18.2",
        "apollo-server-express": "^3.12.1",
        "graphql": "^16.8.1",
        "mongoose": "^8.0.3",
        "redis": "^4.6.10",
        "jsonwebtoken": "^9.0.2",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "helmet": "^7.1.0",
        "express-rate-limit": "^7.1.5",
        "express-validator": "^7.0.1",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.0",
        "winston": "^3.11.0",
        "dotenv": "^16.3.1",
        "joi": "^17.11.0",
        "crypto": "^1.0.1",
        "axios": "^1.6.2",
        "node-cron": "^3.0.3",
        "compression": "^1.7.4",
        "express-mongo-sanitize": "^2.2.0",
        "express-slow-down": "^2.0.1",
        "express-brute": "^1.0.1",
        "express-brute-redis": "^0.0.1",
        "express-request-id": "^1.4.0",
        "express-async-errors": "^3.1.1",
        "multer": "^1.4.5-lts.1",
        "sharp": "^0.33.0",
        "nodemailer": "^6.9.7",
        "stripe": "^14.7.0",
        "twilio": "^4.19.0",
        "firebase-admin": "^11.11.1",
        "socket.io": "^4.7.4",
        "bull": "^4.12.2",
        "ioredis": "^5.3.2",
        "prometheus-client": "^15.0.0",
        "express-prometheus-middleware": "^1.2.0"
    },
    "devDependencies": {
        "nodemon": "^3.0.2",
        "jest": "^29.7.0",
        "supertest": "^6.3.3",
        "eslint": "^8.55.0",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-plugin-import": "^2.29.0",
        "@types/jest": "^29.5.8",
        "faker": "^6.6.6",
        "mongodb-memory-server": "^9.1.3"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=8.0.0"
    }
}