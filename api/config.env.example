# Server Configuration
NODE_ENV=development
PORT=3001
API_VERSION=v1
API_BASE_URL=http://localhost:3001/api/v1

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/cornman_api
REDIS_URL=redis://localhost:6379

# Authentication & Security
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=24h
API_KEY_SECRET=your-api-key-secret-here
ENCRYPTION_KEY=your-32-character-encryption-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# External Services
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@cornman.com

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret-key
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_TIMEOUT=5000

# Monitoring & Analytics
PROMETHEUS_PORT=9090
LOG_LEVEL=info
ENABLE_METRICS=true

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,https://cornman.com
CORS_CREDENTIALS=true

# API Documentation
SWAGGER_TITLE=CORNMAN Public API
SWAGGER_DESCRIPTION=Comprehensive API for CORNMAN third-party integrations
SWAGGER_VERSION=1.0.0
SWAGGER_CONTACT_NAME=CORNMAN API Team
SWAGGER_CONTACT_EMAIL=api@cornman.com
SWAGGER_CONTACT_URL=https://cornman.com/api

# Partner Integrations
GRABFOOD_API_KEY=your_grab_food_api_key
FOODPANDA_API_KEY=your_foodpanda_api_key
QUICKBOOKS_CLIENT_ID=your_quickbooks_client_id
QUICKBOOKS_CLIENT_SECRET=your_quickbooks_client_secret
HUBSPOT_API_KEY=your_hubspot_api_key
MAILCHIMP_API_KEY=your_mailchimp_api_key

# Feature Flags
ENABLE_GRAPHQL=true
ENABLE_WEBHOOKS=true
ENABLE_ANALYTICS=true
ENABLE_PARTNER_INTEGRATIONS=true
ENABLE_SANDBOX_MODE=false
